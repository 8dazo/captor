{
  "name": "captar",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm --filter @captar/types build && pnpm --filter @captar/config build && pnpm --filter @captar/utils build && turbo lint",
    "test": "turbo test",
    "demo:live": "pnpm --filter @captar/types build && pnpm --filter @captar/config build && pnpm --filter @captar/utils build && pnpm --filter @captar/sdk build && node demo/live-openai-demo.mjs",
    "db:generate": "prisma generate --schema db/prisma/schema.prisma",
    "db:push": "prisma db push --schema db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema db/prisma/schema.prisma",
    "db:seed": "tsx db/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "openai": "^6.33.0"
  }
}
