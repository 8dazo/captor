{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "AUTH_SECRET", "AUTH_URL"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.{ts,tsx}", "**/*.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["**/*.test.ts", "**/*.spec.ts"],
      "outputs": ["coverage/**"]
    }
  }
}
