    "@content-collections/cli": "0.1.6",
    "@content-collections/core": "0.8.0",
    "@content-collections/mdx": "0.2.0",
    "@content-collections/next": "0.2.4",
    "@next/bundle-analyzer": "15.1.2",
    "@svgr/webpack": "8.1.0",
    "@types/mdast": "4.0.4",
    "@types/node": "22.10.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/unist": "3.0.3",
