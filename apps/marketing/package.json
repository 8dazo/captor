{
  "name": "marketing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "content-collections build && next build",
    "build:content": "content-collections build",
    "start": "next start --port 3001",
    "analyze": "BUNDLE_ANALYZE=both next build",
    "clean": "git clean -xdf .cache .content-collections .next .turbo build dist node_modules",
    "format": "prettier --check \"**/*.{js,cjs,mjs,ts,tsx,mdx}\"",
    "format:fix": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,mdx}\"",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint --fix .",
    "typecheck": "content-collections build && tsc --noEmit",
    "postinstall": "content-collections build"
  },
  "dependencies": {
    "@hookform/resolvers": "3.9.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "0.11.1",
    "@tanstack/react-table": "8.20.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "4.4.0",
    "framer-motion": "11.15.0",
    "lucide-react": "0.468.0",
    "mdast-util-toc": "7.1.0",
    "next": "15.1.2",
    "next-secure-headers": "2.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "7.54.1",
    "react-is": "^19.1.0",
    "react-remove-scroll": "^2.7.1",
    "recharts": "2.15.4",
